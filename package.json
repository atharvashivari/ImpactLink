{
  "name": "crowdfunding",
  "version": "1.0.0",
  "description": "This is a crowdfunding platform built using **React** for the frontend. The platform allows users to explore campaigns, create their own, and contribute to existing ones. It features authentication, campaign management, and a modern UI.",
  "main": "index.js",
  "scripts": {
    "server": "npm run dev --prefix impactlink-backend",
    "client": "npm run dev --prefix impactlink-frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start": "node impactlink-backend/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atharvashivari/ImpactLink.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/atharvashivari/ImpactLink/issues"
  },
  "homepage": "https://github.com/atharvashivari/ImpactLink#readme",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.9"
  }
}
